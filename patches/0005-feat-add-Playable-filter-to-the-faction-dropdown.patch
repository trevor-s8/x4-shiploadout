From 976fd81932babd85eb3ff0c62d35279953e4a44b Mon Sep 17 00:00:00 2001
From: patch <patch@local>
Date: Tue, 7 Jul 2026 05:50:12 +0000
Subject: [PATCH] feat: add 'Playable' filter to the faction dropdown
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Excludes ships that exist in the game files but aren't actually ownable/
flyable by the player in vanilla X4. Researched against current X4 forum
and wiki consensus: the rest of the Xenon roster (N, M, P, F, B, PE, SE,
K, I, H) and all Kha'ak ships ARE legitimately capturable (bail-then-claim
or boarding) and flyable per intended 9.x mechanics, so they stay in by
default and under this filter.

The one exception is the Xenon M0 (Timelines) — in-fiction a disabled
superweapon/story set-piece, with no vanilla capture path (dedicated mods
exist for it and even those describe it as effectively uncapturable).
That's the only ship currently in UNPLAYABLE_SHIP_IDS (src/format.ts);
the constant is a deliberately small, documented, easy-to-audit exclusion
list rather than a faction-wide rule, since blanket-excluding Xenon or
Kha'ak would have been wrong.

Implemented as a sentinel value in the existing faction <select> (not a
separate control), so it participates in the same cascading-filter logic
as every other facet.
---
 src/format.ts             | 16 ++++++++++++++++
 src/views/ShipBrowser.tsx | 14 ++++++++++----
 2 files changed, 26 insertions(+), 4 deletions(-)

diff --git a/src/format.ts b/src/format.ts
index d8f4336..d5b7e18 100644
--- a/src/format.ts
+++ b/src/format.ts
@@ -112,3 +112,19 @@ export const CLASS_GROUPS: [string, string[]][] = [
   ['Mining & Salvage', ['miner', 'largeminer', 'scavenger', 'tug', 'compactor']],
   ['Construction', ['builder']],
 ];
+
+/**
+ * Ships that exist in the game files but aren't ones the player can actually own and fly
+ * in vanilla X4 — as opposed to the rest of the Xenon/Kha'ak roster (N, M, P, F, B, PE, SE,
+ * K, I, H, Ravager, etc.), all of which the player can legitimately capture (bail-then-claim
+ * or full boarding, per intended 9.x mechanics) and pilot like any other faction's hull.
+ *
+ * Currently that's just the Xenon M0 (Timelines): in-fiction it's a disabled superweapon/
+ * story set-piece, and outside of dedicated mods there's no vanilla capture path for it —
+ * it never spawns as a capturable, crewed unit the way the rest of the Xenon fleet does.
+ * Revisit this list if a future patch/DLC changes what's actually flyable.
+ */
+export const UNPLAYABLE_SHIP_IDS = new Set<string>([
+  'ship_xen_xl_mothership_01', // M0 — Timelines story/superweapon set-piece, not a normal capture
+]);
+
diff --git a/src/views/ShipBrowser.tsx b/src/views/ShipBrowser.tsx
index 8df8fbe..c0edb06 100644
--- a/src/views/ShipBrowser.tsx
+++ b/src/views/ShipBrowser.tsx
@@ -2,10 +2,14 @@ import { useEffect, useMemo, useState } from 'react';
 import type { GameData, Ship, Loadout, Derived, Weapon } from '../types';
 import type { RoleFit } from '../engine/optimizer';
 import { roleMap, type Role } from '../data/roles';
-import { SIZE_LABEL, CLASS_LABEL, CLASS_GROUPS, fmt } from '../format';
+import { SIZE_LABEL, CLASS_LABEL, CLASS_GROUPS, UNPLAYABLE_SHIP_IDS, fmt } from '../format';
 import { compatible, derive, emptyLoadout } from '../engine/derive';
 
 const SIZES = ['s', 'm', 'l', 'xl'] as const;
+/** Sentinel value for the faction dropdown's "Playable" entry — filters out the handful of
+ *  ships (currently just the Xenon M0) that exist in the data but aren't actually flyable by
+ *  the player in vanilla, rather than picking one specific faction. */
+const PLAYABLE_FILTER = '__playable__';
 
 interface StatSort { id: string; label: string; get: (s: Ship, ctx: SortCtx) => number; fmt: (v: number) => string; tip?: string }
 interface SortCtx { bestDerived: Map<string, Derived>; bestMiningDerived: Map<string, Derived> }
@@ -130,7 +134,7 @@ export default function ShipBrowser({ data, fits, roles, onOpen }: {
     (!f.q || !q || s.name.toLowerCase().includes(q.toLowerCase())) &&
     (!f.size || !size || s.size === size) &&
     (!f.cls || !cls || s.class === cls) &&
-    (!f.faction || !faction || s.factions.includes(faction));
+    (!f.faction || !faction || (faction === PLAYABLE_FILTER ? !UNPLAYABLE_SHIP_IDS.has(s.id) : s.factions.includes(faction)));
 
   const availSizes = useMemo(() =>
     SIZES.filter(sz => data.ships.some(s => s.size === sz && matches(s, { q: true, cls: true, faction: true }))),
@@ -169,7 +173,7 @@ export default function ShipBrowser({ data, fits, roles, onOpen }: {
   // auto-clear any selection its own facet no longer offers
   useEffect(() => { if (size && !availSizes.includes(size as typeof SIZES[number])) setSize(''); }, [size, availSizes]);
   useEffect(() => { if (cls && !availClasses.has(cls)) setCls(''); }, [cls, availClasses]);
-  useEffect(() => { if (faction && !availFactions.includes(faction)) setFaction(''); }, [faction, availFactions]);
+  useEffect(() => { if (faction && faction !== PLAYABLE_FILTER && !availFactions.includes(faction)) setFaction(''); }, [faction, availFactions]);
   useEffect(() => {
     if (!roleSort || !fits) return;
     const isStat = STAT_SORTS.some(x => x.id === roleSort);
@@ -212,8 +216,10 @@ export default function ShipBrowser({ data, fits, roles, onOpen }: {
             ) : null;
           })}
         </select>
-        <select value={faction} onChange={e => setFaction(e.target.value)}>
+        <select value={faction} onChange={e => setFaction(e.target.value)}
+          title="Playable excludes the handful of ships you can't actually own and fly in vanilla — currently just the Xenon M0 story ship. Most Xenon and Kha'ak ships ARE capturable and flyable, so they stay in.">
           <option value="">All factions</option>
+          <option value={PLAYABLE_FILTER}>★ Playable</option>
           {availFactions.map(f => <option key={f} value={f}>{data.factions[f] ?? f}</option>)}
         </select>
         <select value={roleSort} onChange={e => setRoleSort(e.target.value)} title={STAT_SORTS.find(x => x.id === roleSort)?.tip}>
