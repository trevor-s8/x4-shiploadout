From 6096e0b24335b2ec824bf1f1a7f4d89501984dc2 Mon Sep 17 00:00:00 2001
From: patch <patch@local>
Date: Tue, 7 Jul 2026 14:10:24 +0000
Subject: [PATCH] feat: allow gamedata to load from an inlined
 window.__GAMEDATA__ global
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Supports building a fully static/offline distribution (e.g. for users
without Node/npm) by inlining gamedata.json as a preceding <script>
tag instead of relying on runtime fetch(). Falls back to the normal
fetch() path when the global isn't present, so normal dev/prod serving
is unaffected.

Note: confirmed this alone doesn't make file:// double-click work —
Vite's module/CORS handling blocks even the JS/CSS asset loads under
file://, independent of the data-fetching mechanism. Real distribution
to non-Node users still needs a (tiny, local-only) HTTP server; see
the separate x4-loadout-planner-windows.zip deliverable.
---
 src/App.tsx | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/src/App.tsx b/src/App.tsx
index 5e1a264..dd270ea 100644
--- a/src/App.tsx
+++ b/src/App.tsx
@@ -61,8 +61,10 @@ export default function App() {
   };
 
   useEffect(() => {
-    fetch(`${import.meta.env.BASE_URL}data/gamedata.json`)
-      .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json(); })
+    const inlined = (window as unknown as { __GAMEDATA__?: GameData }).__GAMEDATA__;
+    const load = inlined ? Promise.resolve(inlined) : fetch(`${import.meta.env.BASE_URL}data/gamedata.json`)
+      .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json(); });
+    load
       .then((d: GameData) => {
         setData(d);
         const m = location.hash.match(/b=([A-Za-z0-9_-]+)/);
-- 
