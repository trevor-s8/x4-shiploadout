From 8e68d556828be6698aa1a805c20c5fe70d45c04d Mon Sep 17 00:00:00 2001
From: patch <patch@local>
Date: Tue, 7 Jul 2026 20:42:35 +0000
Subject: [PATCH] fix: give the sort dropdown's 'Sort: name' option a header,
 matching the rest

It sat bare at the top of the <select> while every other option was
grouped under an <optgroup> (General, Mobility, Combat, Mining, By role
fit). Wrapped it in its own 'Default' optgroup for visual consistency.
---
 src/views/ShipBrowser.tsx | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/views/ShipBrowser.tsx b/src/views/ShipBrowser.tsx
index cc179be..81db828 100644
--- a/src/views/ShipBrowser.tsx
+++ b/src/views/ShipBrowser.tsx
@@ -266,7 +266,9 @@ export default function ShipBrowser({ data, fits, roles, onOpen }: {
           {availFactions.map(f => <option key={f} value={f}>{data.factions[f] ?? f}</option>)}
         </select>
         <select value={roleSort} onChange={e => setRoleSort(e.target.value)} title={STAT_SORTS.find(x => x.id === roleSort)?.tip}>
-          <option value="">Sort: name</option>
+          <optgroup label="Default">
+            <option value="">Sort: name</option>
+          </optgroup>
           <optgroup label="General">
             {STAT_SORTS.filter(x => ['hull', 'cargo', 'crew'].includes(x.id)).map(x => <option key={x.id} value={x.id}>{x.label}</option>)}
           </optgroup>
-- 
