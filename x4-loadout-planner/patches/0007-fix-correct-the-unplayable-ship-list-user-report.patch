From 116db01673ffce488a998174f5529c0448c12523 Mon Sep 17 00:00:00 2001
From: patch <patch@local>
Date: Tue, 7 Jul 2026 14:01:43 +0000
Subject: [PATCH] fix: correct the unplayable ship list (user-reported,
 re-researched)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Patch 0005 shipped with only the Xenon M0 excluded, based on a search
that over-weighted a 2019 thread (K/I capture was a bug, patched out)
and modded-game reports. Corrected against current vanilla mechanics:

Xenon — capturable set is exactly F, B, PE, SE (bail-then-claim) and
H (boardable, very high difficulty). Excluded: the classic-generation
hulls that never bail (N, M, P, T, S), the unboardable capitals (K, I),
and the M0. The 'Capturable Xenon SM' and 'Capturable Xenon XL' mods
exist precisely to add capture paths for those hulls, which is strong
evidence none of them have one in vanilla.

Kha'ak — the entire faction is non-flyable in vanilla, Ravager and
Obliterator included. Capture mods note the hulls have no airlocks and
no cockpit spawn point; there is no bail or boarding path for any of
them.

Net: 14 excluded ships, Playable filter shows 242 of 256. Selecting
the Xenon or Kha'ak faction directly still lists every hull.
---
 src/format.ts             | 36 +++++++++++++++++++++++++++++-------
 src/views/ShipBrowser.tsx |  8 ++++----
 2 files changed, 33 insertions(+), 11 deletions(-)

diff --git a/src/format.ts b/src/format.ts
index d5b7e18..aeb46b1 100644
--- a/src/format.ts
+++ b/src/format.ts
@@ -115,16 +115,38 @@ export const CLASS_GROUPS: [string, string[]][] = [
 
 /**
  * Ships that exist in the game files but aren't ones the player can actually own and fly
- * in vanilla X4 — as opposed to the rest of the Xenon/Kha'ak roster (N, M, P, F, B, PE, SE,
- * K, I, H, Ravager, etc.), all of which the player can legitimately capture (bail-then-claim
- * or full boarding, per intended 9.x mechanics) and pilot like any other faction's hull.
+ * in vanilla X4.
+ *
+ * Xenon — the vanilla-capturable set is exactly: F, B, PE, SE (can be forced to bail, then
+ * claimed) and H (boardable, very high difficulty). The classic-generation hulls (N, M, P,
+ * T, S) never bail, and K / I cannot be boarded — dedicated mods ("Capturable Xenon SM",
+ * "Capturable Xenon XL") exist precisely to add those capture paths. The M0 (Timelines) is
+ * a story set-piece superweapon with no capture path at all.
+ *
+ * Kha'ak — none are player-flyable in vanilla. Capture mods exist, and even those note the
+ * ships have no airlocks or cockpit spawn point, so the player can never physically enter
+ * one; there is no vanilla bail/boarding path for any Kha'ak hull, Ravager and Obliterator
+ * included.
  *
- * Currently that's just the Xenon M0 (Timelines): in-fiction it's a disabled superweapon/
- * story set-piece, and outside of dedicated mods there's no vanilla capture path for it —
- * it never spawns as a capturable, crewed unit the way the rest of the Xenon fleet does.
  * Revisit this list if a future patch/DLC changes what's actually flyable.
  */
 export const UNPLAYABLE_SHIP_IDS = new Set<string>([
-  'ship_xen_xl_mothership_01', // M0 — Timelines story/superweapon set-piece, not a normal capture
+  // Xenon — classic generation, no bail mechanic
+  'ship_xen_s_fighter_01_a',      // N
+  'ship_xen_s_fighter_02_a',      // M
+  'ship_xen_s_scout_01_a',        // T
+  'ship_xen_m_fighter_01_a',      // P
+  'ship_xen_m_miner_01_a',        // S
+  // Xenon — capitals, not boardable in vanilla (unlike the H)
+  'ship_xen_xl_destroyer_01_a',   // K
+  'ship_xen_xl_carrier_01_a',     // I
+  'ship_xen_xl_mothership_01',    // M0 — Timelines story/superweapon set-piece
+  // Kha'ak — entire faction is non-flyable in vanilla (no airlocks/cockpit)
+  'ship_kha_s_fighter_01_a',      // Protector
+  'ship_kha_s_fighter_02_a',      // Forager
+  'ship_kha_m_fighter_01_a',      // Queen's Guard
+  'ship_kha_m_fighter_02_a',      // Hive Guard
+  'ship_kha_l_destroyer_01_a',    // Ravager
+  'ship_kha_xl_battleship_01_a',  // Obliterator
 ]);
 
diff --git a/src/views/ShipBrowser.tsx b/src/views/ShipBrowser.tsx
index c0edb06..374f638 100644
--- a/src/views/ShipBrowser.tsx
+++ b/src/views/ShipBrowser.tsx
@@ -6,9 +6,9 @@ import { SIZE_LABEL, CLASS_LABEL, CLASS_GROUPS, UNPLAYABLE_SHIP_IDS, fmt } from
 import { compatible, derive, emptyLoadout } from '../engine/derive';
 
 const SIZES = ['s', 'm', 'l', 'xl'] as const;
-/** Sentinel value for the faction dropdown's "Playable" entry — filters out the handful of
- *  ships (currently just the Xenon M0) that exist in the data but aren't actually flyable by
- *  the player in vanilla, rather than picking one specific faction. */
+/** Sentinel value for the faction dropdown's "Playable" entry — filters out the ships that
+ *  exist in the data but aren't flyable by the player in vanilla (all Kha'ak, plus the Xenon
+ *  hulls with no capture path). See UNPLAYABLE_SHIP_IDS in format.ts for the sourced list. */
 const PLAYABLE_FILTER = '__playable__';
 
 interface StatSort { id: string; label: string; get: (s: Ship, ctx: SortCtx) => number; fmt: (v: number) => string; tip?: string }
@@ -217,7 +217,7 @@ export default function ShipBrowser({ data, fits, roles, onOpen }: {
           })}
         </select>
         <select value={faction} onChange={e => setFaction(e.target.value)}
-          title="Playable excludes the handful of ships you can't actually own and fly in vanilla — currently just the Xenon M0 story ship. Most Xenon and Kha'ak ships ARE capturable and flyable, so they stay in.">
+          title="Playable hides ships you can't own and fly in vanilla: all Kha'ak, and the Xenon hulls with no capture path (N, M, P, T, S, K, I, M0). The capturable Xenon — F, B, PE, SE, and the boardable H — stay in.">
           <option value="">All factions</option>
           <option value={PLAYABLE_FILTER}>★ Playable</option>
           {availFactions.map(f => <option key={f} value={f}>{data.factions[f] ?? f}</option>)}
